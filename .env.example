# llm-router — real-LLM backend config.
# Copy to `.env` and fill in. `.env` is gitignored; never commit real credentials.

# ── Backend selection ─────────────────────────────────────────────────────────
# auto (default) = Bedrock if AWS creds present, else Anthropic API key, else mock.
# Force a backend: bedrock | anthropic | mock
LLM_ROUTER_PROVIDER=bedrock

# ── AWS Bedrock (the repo convention) ─────────────────────────────────────────
AWS_REGION=us-west-2

# Option A — standard AWS IAM credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=          # only if using temporary STS credentials

# Option B — a named profile from ~/.aws/credentials (leave the keys above blank)
# AWS_PROFILE=default

# Option C — a Bedrock API key (bearer token)
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key

# Bedrock inference-profile IDs (override the defaults if your account differs).
# "global." routes for max availability; swap to "us." if you lack global profiles.
# BEDROCK_SMALL_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_LARGE_MODEL=global.anthropic.claude-opus-4-6-v1

# ── First-party Anthropic API (only if LLM_ROUTER_PROVIDER=anthropic) ─────────
# ANTHROPIC_API_KEY=sk-ant-...
